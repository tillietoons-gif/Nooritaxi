generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  MERCHANT
  SUPPORT
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum DriverStatus {
  OFFLINE
  ONLINE
  BUSY
  SUSPENDED
}

enum DriverTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum VehicleType {
  CAR
  MOTORBIKE
  RICKSHAW
  VAN
  TRUCK
  BICYCLE
}

enum TripStatus {
  REQUESTED
  ACCEPTED
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  CART
  PLACED
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DeliveryStatus {
  REQUESTED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum WalletType {
  CUSTOMER
  DRIVER
  MERCHANT
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  RIDE_PAYMENT
  DELIVERY_PAYMENT
  ORDER_PAYMENT
  DRIVER_PAYOUT
  MERCHANT_PAYOUT
  REFUND
  PROMO_CREDIT
  LOYALTY_CREDIT
  REFERRAL_CREDIT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PaymentMethod {
  CASH
  WALLET
  CARD
  BANK_TRANSFER
}

enum RestaurantStatus {
  PENDING
  OPEN
  CLOSED
  SUSPENDED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
  WALLET_CREDIT
}

enum PromotionScope {
  RIDES
  FOOD
  DELIVERY
  WALLET
  GLOBAL
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  READ
  FAILED
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReviewTargetType {
  DRIVER
  RIDER
  RESTAURANT
  ORDER
  DELIVERY
}

enum DocumentType {
  ID_CARD
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  INSURANCE
  BACKGROUND_CHECK
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                   String              @id @default(cuid())
  phone                String              @unique
  email                String?             @unique
  name                 String?
  password             String
  role                 UserRole            @default(RIDER)
  status               UserStatus          @default(PENDING_VERIFICATION)
  isVerified           Boolean             @default(false)
  locale               String              @default("fa-AF")
  preferredLanguage    String              @default("fa")
  referralCode         String              @unique
  referredById         String?
  lastSeenAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  referredBy           User?               @relation("UserReferrals", fields: [referredById], references: [id])
  referrals            User[]              @relation("UserReferrals")
  riderProfile         Rider?
  driverProfile        Driver?
  wallets              Wallet[]
  restaurants          Restaurant[]        @relation("RestaurantOwner")
  tripsAsCustomer      Trip[]              @relation("CustomerTrips")
  tripsAsDriver        Trip[]              @relation("DriverTrips")
  orders               Order[]
  deliveriesAsSender   Delivery[]          @relation("DeliverySender")
  deliveriesAsDriver   Delivery[]          @relation("DeliveryDriver")
  reviewsAuthored      Review[]            @relation("ReviewsAuthored")
  notifications        Notification[]
  supportTickets       SupportTicket[]     @relation("TicketRequester")
  assignedTickets      SupportTicket[]     @relation("TicketAssignee")
  loyaltyAccount       LoyaltyAccount?
  promotionRedemptions PromotionRedemption[]
  pushDevices          PushDevice[]
  supportMessages      SupportMessage[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  verifiedDocuments    DriverDocument[]    @relation("DocumentVerifier")

  @@index([role, status])
  @@index([createdAt])
}

model Rider {
  id              String   @id @default(cuid())
  userId          String   @unique
  savedPlaces     Json?
  accessibility   Json?
  totalTrips      Int      @default(0)
  ratingAverage   Float    @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ratingAverage])
}

model Driver {
  id                  String        @id @default(cuid())
  userId              String        @unique
  nationalIdNumber    String?
  licenseNumber       String?
  status              DriverStatus  @default(OFFLINE)
  tier                DriverTier    @default(BRONZE)
  currentLat          Float?
  currentLng          Float?
  ratingAverage       Float         @default(5)
  completedTrips      Int           @default(0)
  completedDeliveries Int           @default(0)
  acceptsCash         Boolean       @default(true)
  acceptsWallet       Boolean       @default(true)
  verifiedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicles            Vehicle[]
  documents           DriverDocument[]

  @@index([status, tier])
  @@index([currentLat, currentLng])
}

model Vehicle {
  id            String      @id @default(cuid())
  driverId      String
  type          VehicleType
  make          String?
  model         String?
  year          Int?
  plateNumber   String      @unique
  color         String?
  capacity      Int         @default(4)
  isActive      Boolean     @default(true)
  documents     Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  driver        Driver      @relation(fields: [driverId], references: [id], onDelete: Cascade)
  trips         Trip[]
  deliveries    Delivery[]

  @@index([driverId, isActive])
  @@index([type])
}

model DriverDocument {
  id         String         @id @default(cuid())
  driverId   String
  type       DocumentType
  url        String
  status     DocumentStatus @default(PENDING)
  verifiedAt DateTime?
  verifiedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  driver     Driver         @relation(fields: [driverId], references: [userId], onDelete: Cascade)
  admin      User?          @relation("DocumentVerifier", fields: [verifiedBy], references: [id])

  @@index([driverId, status])
}

model Trip {
  id              String        @id @default(cuid())
  customerId      String
  driverId        String?
  vehicleId       String?
  pickupLocation  String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLocation String
  dropoffLat      Float?
  dropoffLng      Float?
  status          TripStatus    @default(REQUESTED)
  fare            Decimal?      @db.Decimal(10, 2)
  baseFare        Decimal?      @db.Decimal(10, 2)
  surgeMultiplier Float         @default(1)
  distance        Float?
  duration        Int?
  paymentMethod   PaymentMethod @default(CASH)
  safetyCode      String?
  notes           String?
  requestedAt     DateTime      @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer        User          @relation("CustomerTrips", fields: [customerId], references: [id])
  driver          User?         @relation("DriverTrips", fields: [driverId], references: [id])
  vehicle         Vehicle?      @relation(fields: [vehicleId], references: [id])
  reviews         Review[]
  transactions    Transaction[]

  @@index([customerId, status, createdAt])
  @@index([driverId, status, createdAt])
}

model Restaurant {
  id              String            @id @default(cuid())
  ownerId         String
  name            String
  description     String?
  phone           String?
  address         String
  lat             Float?
  lng             Float?
  cuisineTypes    String[]
  status          RestaurantStatus  @default(PENDING)
  openingHours    Json?
  deliveryRadius  Float?
  avgPrepMinutes  Int               @default(25)
  ratingAverage   Float             @default(5)
  lowBandwidthMenu Boolean          @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  owner           User              @relation("RestaurantOwner", fields: [ownerId], references: [id])
  menuItems       MenuItem[]
  orders          Order[]
  reviews         Review[]

  @@index([status, ratingAverage])
  @@index([ownerId])
}

model MenuItem {
  id             String      @id @default(cuid())
  restaurantId   String
  name           String
  description    String?
  price          Decimal     @db.Decimal(10, 2)
  imageUrl       String?
  category       String?
  isAvailable    Boolean     @default(true)
  preparationMin Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  restaurant     Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]

  @@index([restaurantId, isAvailable])
  @@index([category])
}

model Order {
  id              String        @id @default(cuid())
  riderId         String
  restaurantId    String
  status          OrderStatus   @default(PLACED)
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @default(CASH)
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  notes           String?
  placedAt        DateTime      @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rider           User          @relation(fields: [riderId], references: [id])
  restaurant      Restaurant    @relation(fields: [restaurantId], references: [id])
  items           OrderItem[]
  delivery        Delivery?
  reviews         Review[]
  transactions    Transaction[]

  @@index([riderId, status, createdAt])
  @@index([restaurantId, status, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int      @default(1)
  unitPrice  Decimal  @db.Decimal(10, 2)
  notes      String?

  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

model Delivery {
  id              String         @id @default(cuid())
  orderId         String?        @unique
  senderId        String?
  driverId        String?
  vehicleId       String?
  pickupName      String?
  pickupAddress   String
  pickupLat       Float?
  pickupLng       Float?
  dropoffName     String?
  dropoffAddress  String
  dropoffLat      Float?
  dropoffLng      Float?
  packageType     String?
  packageWeightKg Float?
  status          DeliveryStatus @default(REQUESTED)
  fee             Decimal?       @db.Decimal(10, 2)
  distance        Float?
  proofOfDelivery Json?
  requestedAt     DateTime       @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order           Order?         @relation(fields: [orderId], references: [id])
  sender          User?          @relation("DeliverySender", fields: [senderId], references: [id])
  driver          User?          @relation("DeliveryDriver", fields: [driverId], references: [id])
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  reviews         Review[]
  transactions    Transaction[]

  @@index([driverId, status, createdAt])
  @@index([senderId, status, createdAt])
}

model Wallet {
  id           String        @id @default(cuid())
  userId       String
  type         WalletType    @default(CUSTOMER)
  currency     String        @default("AFN")
  balance      Decimal       @default(0) @db.Decimal(12, 2)
  isFrozen     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, type, currency])
  @@index([userId])
}

model Transaction {
  id              String            @id @default(cuid())
  walletId        String
  tripId          String?
  orderId         String?
  deliveryId      String?
  amount          Decimal           @db.Decimal(12, 2)
  type            TransactionType
  status          TransactionStatus @default(COMPLETED)
  provider        String?
  providerRef     String?
  idempotencyKey  String?           @unique
  description     String?
  metadata        Json?
  createdAt       DateTime          @default(now())

  wallet          Wallet            @relation(fields: [walletId], references: [id])
  trip            Trip?             @relation(fields: [tripId], references: [id])
  order           Order?            @relation(fields: [orderId], references: [id])
  delivery        Delivery?         @relation(fields: [deliveryId], references: [id])

  @@index([walletId, createdAt])
  @@index([type, status, createdAt])
}

model Review {
  id             String           @id @default(cuid())
  authorId       String
  targetType     ReviewTargetType
  targetUserId   String?
  restaurantId   String?
  tripId         String?
  orderId        String?
  deliveryId     String?
  rating         Int
  comment        String?
  isVisible      Boolean          @default(true)
  createdAt      DateTime         @default(now())

  author         User             @relation("ReviewsAuthored", fields: [authorId], references: [id])
  restaurant     Restaurant?      @relation(fields: [restaurantId], references: [id])
  trip           Trip?            @relation(fields: [tripId], references: [id])
  order          Order?           @relation(fields: [orderId], references: [id])
  delivery       Delivery?        @relation(fields: [deliveryId], references: [id])
}

model Promotion {
  id             String                @id @default(cuid())
  code           String                @unique
  title          String
  description    String?
  type           PromotionType
  scope          PromotionScope        @default(GLOBAL)
  value          Decimal               @db.Decimal(10, 2)
  maxDiscount    Decimal?              @db.Decimal(10, 2)
  minSpend       Decimal?              @db.Decimal(10, 2)
  usageLimit     Int?
  perUserLimit   Int                   @default(1)
  startsAt       DateTime
  endsAt         DateTime
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  redemptions    PromotionRedemption[]

  @@index([scope, isActive, startsAt, endsAt])
}

model PromotionRedemption {
  id           String    @id @default(cuid())
  promotionId  String
  userId       String
  orderId      String?
  tripId       String?
  discount     Decimal   @db.Decimal(10, 2)
  createdAt    DateTime  @default(now())

  promotion    Promotion @relation(fields: [promotionId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(QUEUED)
  title       String
  body        String
  data        Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model PushDevice {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  token       String   @unique
  locale      String?
  appVersion  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String                @id @default(cuid())
  requesterId String
  assigneeId  String?
  category    String
  subject     String
  description String
  status      SupportTicketStatus   @default(OPEN)
  priority    SupportTicketPriority @default(NORMAL)
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  resolvedAt  DateTime?

  requester   User                  @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee    User?                 @relation("TicketAssignee", fields: [assigneeId], references: [id])
  messages    SupportMessage[]

  @@index([status, priority, updatedAt])
  @@index([requesterId, createdAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String
  body      String
  metadata  Json?
  createdAt DateTime      @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])
}

model LoyaltyAccount {
  id         String   @id @default(cuid())
  userId     String   @unique
  points     Int      @default(0)
  tier       String   @default("NOORI")
  lifetime   Int      @default(0)
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  action      String
  entityType  String
  entityId    String?
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([phone, usedAt])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model SurgeZone {
  id          String   @id @default(cuid())
  name        String
  city        String
  polygon     Json
  multiplier  Float    @default(1)
  reason      String?
  activeFrom  DateTime
  activeUntil DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city, isActive, activeFrom, activeUntil])
}
