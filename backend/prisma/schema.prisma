generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  RIDER
  DRIVER
  MERCHANT
  SUPPORT
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DELETED
}

enum DriverStatus {
  OFFLINE
  ONLINE
  BUSY
  SUSPENDED
}

enum DriverTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum VehicleType {
  CAR
  MOTORBIKE
  RICKSHAW
  VAN
  TRUCK
  BICYCLE
}

enum TripStatus {
  REQUESTED
  ACCEPTED
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  CART
  PLACED
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum DeliveryStatus {
  REQUESTED
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

enum WalletType {
  CUSTOMER
  DRIVER
  MERCHANT
  FLEET
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  RIDE_PAYMENT
  DELIVERY_PAYMENT
  ORDER_PAYMENT
  DRIVER_PAYOUT
  MERCHANT_PAYOUT
  REFUND
  PROMO_CREDIT
  LOYALTY_CREDIT
  REFERRAL_CREDIT
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum PaymentMethod {
  CASH
  WALLET
  CARD
  BANK_TRANSFER
}

enum RestaurantStatus {
  PENDING
  OPEN
  CLOSED
  SUSPENDED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_DELIVERY
  WALLET_CREDIT
}

enum PromotionScope {
  RIDES
  FOOD
  DELIVERY
  WALLET
  GLOBAL
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  READ
  FAILED
}

enum SupportTicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReviewTargetType {
  DRIVER
  RIDER
  RESTAURANT
  ORDER
  DELIVERY
}

enum DocumentType {
  ID_CARD
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  INSURANCE
  BACKGROUND_CHECK
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                String     @id @default(cuid())
  phone             String     @unique
  email             String?    @unique
  name              String?
  password          String
  role              UserRole   @default(RIDER)
  status            UserStatus @default(PENDING_VERIFICATION)
  isVerified        Boolean    @default(false)
  locale            String     @default("fa-AF")
  preferredLanguage String     @default("fa")
  referralCode      String     @unique
  referredById      String?
  lastSeenAt        DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  referredBy           User?                 @relation("UserReferrals", fields: [referredById], references: [id])
  referrals            User[]                @relation("UserReferrals")
  riderProfile         Rider?
  driverProfile        Driver?
  fleetManager         FleetManager?
  wallets              Wallet[]
  restaurants          Restaurant[]          @relation("RestaurantOwner")
  tripsAsCustomer      Trip[]                @relation("CustomerTrips")
  tripsAsDriver        Trip[]                @relation("DriverTrips")
  orders               Order[]
  deliveriesAsSender   Delivery[]            @relation("DeliverySender")
  deliveriesAsDriver   Delivery[]            @relation("DeliveryDriver")
  reviewsAuthored      Review[]              @relation("ReviewsAuthored")
  notifications        Notification[]
  supportTickets       SupportTicket[]       @relation("TicketRequester")
  assignedTickets      SupportTicket[]       @relation("TicketAssignee")
  loyaltyAccount       LoyaltyAccount?
  promotionRedemptions PromotionRedemption[]
  pushDevices          PushDevice[]
  supportMessages      SupportMessage[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]
  verifiedDocuments    DriverDocument[]      @relation("DocumentVerifier")
  trustedContacts      TrustedContact[]      @relation("UserTrustedContacts")
  sosAlerts            SosAlert[]            @relation("UserSosAlerts")
  adminRoles           AdminRole[]           @relation("UserAdminRoles")

  // Finance & Cash Management
  settlements      Settlement[]     @relation("UserSettlements")
  cashCollected    CashCollection[] @relation("AdminCashCollections")
  refundRequests   RefundRequest[]  @relation("UserRefunds")
  processedRefunds RefundRequest[]  @relation("AdminRefunds")

  // Fraud & Risk
  fraudScore         FraudScore?         @relation("UserFraudScore")
  devices            DeviceFingerprint[] @relation("UserDevices")
  assignedFraudCases FraudCase[]         @relation("AssignedCases")
  targetFraudCases   FraudCase[]         @relation("UserFraudCases")
  fraudAlerts        FraudAlert[]        @relation("UserFraudAlerts")
  investigationNotes InvestigationNote[] @relation("InvestigationNotesAuthor")
  fraudAuditLogs     FraudAuditLog[]     @relation("AdminFraudAuditLogs")
  addedBlacklists    Blacklist[]         @relation("BlacklistAddedBy")
  addedWhitelists    Whitelist[]         @relation("WhitelistAddedBy")

  // Operations
  assignedIncidents   Incident[]               @relation("AssignedIncidents")
  reportedIncidents   Incident[]               @relation("UserIncidents")
  broadcastsSent      CommunicationBroadcast[] @relation("BroadcastsSent")
  operationsAuditLogs OperationsAuditLog[]     @relation("AdminOperationsAuditLogs")

  // Corporate
  employeeProfile Employee? @relation("UserEmployee")

  // Airport
  airportBookings  AirportBooking[]  @relation("UserAirportBookings")
  airportAuditLogs AirportAuditLog[] @relation("AdminAirportAuditLogs")

  @@index([role, status])
  @@index([createdAt])
}

model Rider {
  id            String   @id @default(cuid())
  userId        String   @unique
  savedPlaces   Json?
  accessibility Json?
  totalTrips    Int      @default(0)
  ratingAverage Float    @default(5)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ratingAverage])
}

model Driver {
  id                  String       @id @default(cuid())
  userId              String       @unique
  nationalIdNumber    String?
  licenseNumber       String?
  status              DriverStatus @default(OFFLINE)
  tier                DriverTier   @default(BRONZE)
  currentLat          Float?
  currentLng          Float?
  ratingAverage       Float        @default(5)
  completedTrips      Int          @default(0)
  completedDeliveries Int          @default(0)
  acceptsCash         Boolean      @default(true)
  acceptsWallet       Boolean      @default(true)
  verifiedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  fleetId         String?
  fleet           Fleet?           @relation(fields: [fleetId], references: [id])
  vehicles        Vehicle[]
  documents       DriverDocument[]
  fraudScore      FraudScore?      @relation("DriverFraudScore")
  fraudCases      FraudCase[]      @relation("DriverFraudCases")
  fraudAlerts     FraudAlert[]     @relation("DriverFraudAlerts")
  incidents       Incident[]       @relation("DriverIncidents")
  airportQueues   AirportQueue[]   @relation("DriverAirportQueues")
  airportBookings AirportBooking[] @relation("DriverAirportBookings")

  @@index([status, tier])
  @@index([currentLat, currentLng])
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SUSPENDED
  EXPIRED
}

model Vehicle {
  id                 String        @id @default(cuid())
  driverId           String?
  fleetId            String?
  type               VehicleType
  make               String?
  model              String?
  year               Int?
  plateNumber        String        @unique
  color              String?
  capacity           Int           @default(4)
  isActive           Boolean       @default(true)
  status             VehicleStatus @default(ACTIVE)
  registrationExpiry DateTime?
  insuranceExpiry    DateTime?
  documents          Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  driver        Driver?              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  fleet         Fleet?               @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  trips         Trip[]
  deliveries    Delivery[]
  maintenance   VehicleMaintenance[]
  airportQueues AirportQueue[]

  @@index([driverId, isActive])
  @@index([fleetId, status])
  @@index([type])
}

model DriverDocument {
  id         String         @id @default(cuid())
  driverId   String
  type       DocumentType
  url        String
  status     DocumentStatus @default(PENDING)
  verifiedAt DateTime?
  verifiedBy String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  driver Driver @relation(fields: [driverId], references: [userId], onDelete: Cascade)
  admin  User?  @relation("DocumentVerifier", fields: [verifiedBy], references: [id])

  @@index([driverId, status])
}

model Trip {
  id              String        @id @default(cuid())
  customerId      String
  driverId        String?
  vehicleId       String?
  pickupLocation  String
  pickupLat       Float?
  pickupLng       Float?
  dropoffLocation String
  dropoffLat      Float?
  dropoffLng      Float?
  status          TripStatus    @default(REQUESTED)
  fare            Decimal?      @db.Decimal(10, 2)
  baseFare        Decimal?      @db.Decimal(10, 2)
  surgeMultiplier Float         @default(1)
  distance        Float?
  duration        Int?
  paymentMethod   PaymentMethod @default(CASH)
  safetyCode      String?
  notes           String?
  requestedAt     DateTime      @default(now())
  acceptedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  scheduledFor    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer           User                @relation("CustomerTrips", fields: [customerId], references: [id])
  driver             User?               @relation("DriverTrips", fields: [driverId], references: [id])
  vehicle            Vehicle?            @relation(fields: [vehicleId], references: [id])
  reviews            Review[]
  transactions       Transaction[]
  loyaltyTransaction LoyaltyTransaction?
  refundRequests     RefundRequest[]
  incidents          Incident[]          @relation("TripIncidents")
  travelApprovals    TravelApproval[]    @relation("TripTravelApproval")
  airportBooking     AirportBooking?     @relation("TripAirportBooking")

  @@index([customerId, status, createdAt])
  @@index([driverId, status, createdAt])
}

model Restaurant {
  id               String           @id @default(cuid())
  ownerId          String
  name             String
  description      String?
  phone            String?
  address          String
  lat              Float?
  lng              Float?
  cuisineTypes     String[]
  status           RestaurantStatus @default(PENDING)
  openingHours     Json?
  deliveryRadius   Float?
  avgPrepMinutes   Int              @default(25)
  ratingAverage    Float            @default(5)
  lowBandwidthMenu Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  owner      User        @relation("RestaurantOwner", fields: [ownerId], references: [id])
  menuItems  MenuItem[]
  orders     Order[]
  reviews    Review[]
  fraudScore FraudScore? @relation("MerchantFraudScore")
  fraudCases FraudCase[] @relation("MerchantFraudCases")

  @@index([status, ratingAverage])
  @@index([ownerId])
}

model MenuItem {
  id             String   @id @default(cuid())
  restaurantId   String
  name           String
  description    String?
  price          Decimal  @db.Decimal(10, 2)
  imageUrl       String?
  category       String?
  isAvailable    Boolean  @default(true)
  preparationMin Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([restaurantId, isAvailable])
  @@index([category])
}

model Order {
  id              String        @id @default(cuid())
  riderId         String
  restaurantId    String
  status          OrderStatus   @default(PLACED)
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  deliveryFee     Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  paymentMethod   PaymentMethod @default(CASH)
  deliveryAddress String
  deliveryLat     Float?
  deliveryLng     Float?
  notes           String?
  placedAt        DateTime      @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  rider          User            @relation(fields: [riderId], references: [id])
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id])
  items          OrderItem[]
  delivery       Delivery?
  reviews        Review[]
  transactions   Transaction[]
  refundRequests RefundRequest[]

  @@index([riderId, status, createdAt])
  @@index([restaurantId, status, createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(10, 2)
  notes      String?

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Delivery {
  id              String         @id @default(cuid())
  orderId         String?        @unique
  senderId        String?
  driverId        String?
  vehicleId       String?
  pickupName      String?
  pickupAddress   String
  pickupLat       Float?
  pickupLng       Float?
  dropoffName     String?
  dropoffAddress  String
  dropoffLat      Float?
  dropoffLng      Float?
  packageType     String?
  packageWeightKg Float?
  status          DeliveryStatus @default(REQUESTED)
  fee             Decimal?       @db.Decimal(10, 2)
  distance        Float?
  proofOfDelivery Json?
  requestedAt     DateTime       @default(now())
  deliveredAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order          Order?          @relation(fields: [orderId], references: [id])
  sender         User?           @relation("DeliverySender", fields: [senderId], references: [id])
  driver         User?           @relation("DeliveryDriver", fields: [driverId], references: [id])
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id])
  reviews        Review[]
  transactions   Transaction[]
  refundRequests RefundRequest[]

  @@index([driverId, status, createdAt])
  @@index([senderId, status, createdAt])
}

model Wallet {
  id        String     @id @default(cuid())
  userId    String
  type      WalletType @default(CUSTOMER)
  currency  String     @default("AFN")
  balance   Decimal    @default(0) @db.Decimal(12, 2)
  isFrozen  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, type, currency])
  @@index([userId])
}

model Transaction {
  id             String            @id @default(cuid())
  walletId       String
  tripId         String?
  orderId        String?
  deliveryId     String?
  amount         Decimal           @db.Decimal(12, 2)
  type           TransactionType
  status         TransactionStatus @default(COMPLETED)
  provider       String?
  providerRef    String?
  idempotencyKey String?           @unique
  description    String?
  metadata       Json?
  createdAt      DateTime          @default(now())

  wallet   Wallet    @relation(fields: [walletId], references: [id])
  trip     Trip?     @relation(fields: [tripId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])
  delivery Delivery? @relation(fields: [deliveryId], references: [id])

  @@index([walletId, createdAt])
  @@index([type, status, createdAt])
}

model Review {
  id           String           @id @default(cuid())
  authorId     String
  targetType   ReviewTargetType
  targetUserId String?
  restaurantId String?
  tripId       String?
  orderId      String?
  deliveryId   String?
  rating       Int
  comment      String?
  isVisible    Boolean          @default(true)
  createdAt    DateTime         @default(now())

  author     User        @relation("ReviewsAuthored", fields: [authorId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])
  trip       Trip?       @relation(fields: [tripId], references: [id])
  order      Order?      @relation(fields: [orderId], references: [id])
  delivery   Delivery?   @relation(fields: [deliveryId], references: [id])
}

model Promotion {
  id           String         @id @default(cuid())
  code         String         @unique
  title        String
  description  String?
  type         PromotionType
  scope        PromotionScope @default(GLOBAL)
  value        Decimal        @db.Decimal(10, 2)
  maxDiscount  Decimal?       @db.Decimal(10, 2)
  minSpend     Decimal?       @db.Decimal(10, 2)
  usageLimit   Int?
  perUserLimit Int            @default(1)
  startsAt     DateTime
  endsAt       DateTime
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  redemptions PromotionRedemption[]

  @@index([scope, isActive, startsAt, endsAt])
}

model PromotionRedemption {
  id          String   @id @default(cuid())
  promotionId String
  userId      String
  orderId     String?
  tripId      String?
  discount    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  promotion Promotion @relation(fields: [promotionId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model Notification {
  id          String              @id @default(cuid())
  userId      String
  channel     NotificationChannel @default(IN_APP)
  status      NotificationStatus  @default(QUEUED)
  title       String
  body        String
  data        Json?
  scheduledAt DateTime?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  platform   String
  token      String   @unique
  locale     String?
  appVersion String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String                @id @default(cuid())
  requesterId String
  assigneeId  String?
  category    String
  subject     String
  description String
  status      SupportTicketStatus   @default(OPEN)
  priority    SupportTicketPriority @default(NORMAL)
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  resolvedAt  DateTime?

  requester User             @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee  User?            @relation("TicketAssignee", fields: [assigneeId], references: [id])
  messages  SupportMessage[]

  @@index([status, priority, updatedAt])
  @@index([requesterId, createdAt])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  body      String
  metadata  Json?
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id])
}

enum LoyaltyTransactionType {
  CREDIT
  DEBIT
}

model LoyaltyTransaction {
  id               String                 @id @default(cuid())
  loyaltyAccountId String
  loyaltyAccount   LoyaltyAccount         @relation(fields: [loyaltyAccountId], references: [id])
  tripId           String?                @unique
  trip             Trip?                  @relation(fields: [tripId], references: [id])
  type             LoyaltyTransactionType
  amount           Int
  description      String?
  createdAt        DateTime               @default(now())
}

model DriverTierConfig {
  id        String     @id @default(cuid())
  tier      DriverTier @unique
  minTrips  Int
  minRating Float
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  userId    String   @unique
  points    Int      @default(0)
  tier      String   @default("NOORI")
  lifetime  Int      @default(0)
  updatedAt DateTime @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model PhoneOtp {
  id        String    @id @default(cuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([phone, usedAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model SurgeZone {
  id          String   @id @default(cuid())
  name        String
  city        String
  polygon     Json
  multiplier  Float    @default(1)
  reason      String?
  activeFrom  DateTime
  activeUntil DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city, isActive, activeFrom, activeUntil])
}

model TrustedContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  phone        String
  relation     String?
  notifyOnSos  Boolean  @default(true)
  notifyOnTrip Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation("UserTrustedContacts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId])
}

enum SosStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

model SosAlert {
  id         String    @id @default(cuid())
  userId     String
  tripId     String?
  status     SosStatus @default(ACTIVE)
  lat        Float?
  lng        Float?
  message    String?
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation("UserSosAlerts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
  @@index([tripId])
}

// ==========================================
// RBAC SYSTEM (Enterprise Permissions)
// ==========================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  admins      AdminRole[]
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "drivers.view"
  module      String // e.g., "drivers"
  action      String // e.g., "view"
  description String?
  createdAt   DateTime @default(now())

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AdminRole {
  adminId   String
  roleId    String
  cityScope String? // Optional city restriction, e.g., "Kabul"
  createdAt DateTime @default(now())

  admin User @relation("UserAdminRoles", fields: [adminId], references: [id], onDelete: Cascade)
  role  Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([adminId, roleId])
}

// ==========================================
// FLEET MANAGEMENT SYSTEM
// ==========================================

enum FleetStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

model Fleet {
  id              String      @id @default(cuid())
  companyName     String
  ownerName       String
  email           String      @unique
  phone           String      @unique
  address         String
  taxNumber       String?
  businessLicense String?
  logo            String?
  status          FleetStatus @default(PENDING)
  cityId          String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  drivers         Driver[]
  vehicles        Vehicle[]
  managers        FleetManager[]
  commissionRules FleetCommissionRule[]
  payoutRequests  FleetPayoutRequest[]
  settlements     Settlement[]
  fraudScore      FraudScore?           @relation("FleetFraudScore")
  fraudCases      FraudCase[]           @relation("FleetFraudCases")
}

model FleetManager {
  id                String   @id @default(cuid())
  fleetId           String
  userId            String   @unique
  canManageDrivers  Boolean  @default(false)
  canManageVehicles Boolean  @default(false)
  canViewEarnings   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VehicleMaintenance {
  id          String   @id @default(cuid())
  vehicleId   String
  serviceDate DateTime
  mileage     Int?
  cost        Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model FleetCommissionRule {
  id        String   @id @default(cuid())
  fleetId   String
  type      String // PERCENTAGE, FLAT, TIERED
  value     Decimal  @db.Decimal(10, 2)
  minTrips  Int? // For TIERED
  maxTrips  Int? // For TIERED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Cascade)
}

enum PayoutMethod {
  BANK_TRANSFER
  MOBILE_MONEY
  CASH
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model FleetPayoutRequest {
  id             String       @id @default(cuid())
  fleetId        String
  amount         Decimal      @db.Decimal(12, 2)
  method         PayoutMethod
  accountDetails String?
  status         PayoutStatus @default(PENDING)
  notes          String?
  processedAt    DateTime?
  processedBy    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  fleet Fleet @relation(fields: [fleetId], references: [id], onDelete: Cascade)
}

// ==========================================
// CASH-BASED FINANCE CENTER
// ==========================================

enum CommissionType {
  FIXED
  PERCENTAGE
}

model SystemCommissionRule {
  id             String         @id @default(cuid())
  serviceType    String // RIDE, DELIVERY, FOOD
  commissionType CommissionType
  value          Decimal        @db.Decimal(10, 2)
  cityId         String? // Null = Global
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([serviceType, isActive])
}

enum SettlementStatus {
  PENDING
  PARTIAL
  COMPLETED
  OVERDUE
}

model Settlement {
  id            String           @id @default(cuid())
  userId        String? // Driver or Merchant
  fleetId       String? // Fleet owner
  periodStart   DateTime
  periodEnd     DateTime
  totalEarned   Decimal          @default(0) @db.Decimal(12, 2)
  platformFee   Decimal          @default(0) @db.Decimal(12, 2)
  cashCollected Decimal          @default(0) @db.Decimal(12, 2)
  netBalance    Decimal          @default(0) @db.Decimal(12, 2) // Positive means we owe them, negative means they owe us
  status        SettlementStatus @default(PENDING)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user            User?            @relation("UserSettlements", fields: [userId], references: [id])
  fleet           Fleet?           @relation(fields: [fleetId], references: [id])
  cashCollections CashCollection[]

  @@index([userId, status])
  @@index([fleetId, status])
  @@index([periodStart, periodEnd])
}

model CashCollection {
  id            String   @id @default(cuid())
  settlementId  String?
  amount        Decimal  @db.Decimal(12, 2)
  collectedBy   String // Admin ID who collected the cash
  collectedFrom String // Driver/Fleet/Merchant ID
  receiptNo     String?
  notes         String?
  collectedAt   DateTime @default(now())

  settlement Settlement? @relation(fields: [settlementId], references: [id])
  admin      User        @relation("AdminCashCollections", fields: [collectedBy], references: [id])

  @@index([collectedBy, collectedAt])
}

model RefundRequest {
  id          String       @id @default(cuid())
  tripId      String?
  orderId     String?
  deliveryId  String?
  userId      String
  amount      Decimal      @db.Decimal(10, 2)
  reason      String
  status      PayoutStatus @default(PENDING)
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  trip     Trip?     @relation(fields: [tripId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])
  delivery Delivery? @relation(fields: [deliveryId], references: [id])
  user     User      @relation("UserRefunds", fields: [userId], references: [id])
  admin    User?     @relation("AdminRefunds", fields: [processedBy], references: [id])

  @@index([status, createdAt])
}

// ==========================================
// FRAUD DETECTION & RISK MANAGEMENT
// ==========================================

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudAlertType {
  GPS_SPOOFING
  FAKE_TRIPS
  REFERRAL_FRAUD
  DUPLICATE_ACCOUNTS
  FINANCIAL_FRAUD
  KYC_FRAUD
  VEHICLE_FRAUD
  DRIVER_COLLUSION
  MERCHANT_FRAUD
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseStatus {
  OPEN
  INVESTIGATING
  ESCALATED
  RESOLVED
  DISMISSED
}

model FraudScore {
  id               String    @id @default(cuid())
  userId           String?   @unique
  driverId         String?   @unique
  merchantId       String?   @unique
  fleetId          String?   @unique
  score            Int       @default(0)
  riskLevel        RiskLevel @default(LOW)
  lastCalculatedAt DateTime  @default(now())
  reasons          Json?

  user     User?       @relation("UserFraudScore", fields: [userId], references: [id])
  driver   Driver?     @relation("DriverFraudScore", fields: [driverId], references: [id])
  merchant Restaurant? @relation("MerchantFraudScore", fields: [merchantId], references: [id])
  fleet    Fleet?      @relation("FleetFraudScore", fields: [fleetId], references: [id])
}

model DeviceFingerprint {
  id            String   @id @default(cuid())
  userId        String?
  deviceId      String   @unique
  os            String?
  appVersion    String?
  ipAddress     String?
  browser       String?
  phoneModel    String?
  lastSeenAt    DateTime @default(now())
  isBlacklisted Boolean  @default(false)

  user User? @relation("UserDevices", fields: [userId], references: [id])

  @@index([deviceId, isBlacklisted])
}

model Blacklist {
  id        String   @id @default(cuid())
  type      String
  value     String   @unique
  reason    String
  addedBy   String
  createdAt DateTime @default(now())

  admin User @relation("BlacklistAddedBy", fields: [addedBy], references: [id])
}

model Whitelist {
  id        String   @id @default(cuid())
  type      String
  value     String   @unique
  reason    String?
  addedBy   String
  createdAt DateTime @default(now())

  admin User @relation("WhitelistAddedBy", fields: [addedBy], references: [id])
}

model FraudCase {
  id               String     @id @default(cuid())
  title            String
  description      String?
  status           CaseStatus @default(OPEN)
  assignedToId     String?
  targetUserId     String?
  targetDriverId   String?
  targetFleetId    String?
  targetMerchantId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  assignedTo     User?       @relation("AssignedCases", fields: [assignedToId], references: [id])
  targetUser     User?       @relation("UserFraudCases", fields: [targetUserId], references: [id])
  targetDriver   Driver?     @relation("DriverFraudCases", fields: [targetDriverId], references: [id])
  targetFleet    Fleet?      @relation("FleetFraudCases", fields: [targetFleetId], references: [id])
  targetMerchant Restaurant? @relation("MerchantFraudCases", fields: [targetMerchantId], references: [id])

  alerts FraudAlert[]
  notes  InvestigationNote[]
}

model FraudAlert {
  id         String         @id @default(cuid())
  type       FraudAlertType
  severity   AlertSeverity
  message    String
  metadata   Json?
  isResolved Boolean        @default(false)
  caseId     String?
  userId     String?
  driverId   String?
  createdAt  DateTime       @default(now())

  case   FraudCase? @relation(fields: [caseId], references: [id])
  user   User?      @relation("UserFraudAlerts", fields: [userId], references: [id])
  driver Driver?    @relation("DriverFraudAlerts", fields: [driverId], references: [id])
}

model InvestigationNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  case   FraudCase @relation(fields: [caseId], references: [id])
  author User      @relation("InvestigationNotesAuthor", fields: [authorId], references: [id])
}

model FraudAuditLog {
  id         String   @id @default(cuid())
  action     String
  entityId   String
  entityType String
  adminId    String
  details    Json?
  createdAt  DateTime @default(now())

  admin User @relation("AdminFraudAuditLogs", fields: [adminId], references: [id])
}

model FraudRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String
  conditions  Json
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// OPERATIONS COMMAND CENTER (OCC)
// ==========================================

enum IncidentType {
  SAFETY
  VEHICLE_BREAKDOWN
  FRAUD
  PAYMENT_ISSUE
  SERVICE_DISRUPTION
  SUPPORT_ESCALATION
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  ASSIGNED
  RESOLVED
  CLOSED
}

model Incident {
  id           String         @id @default(cuid())
  type         IncidentType
  status       IncidentStatus @default(OPEN)
  title        String
  description  String?
  assignedToId String?
  tripId       String?
  driverId     String?
  userId       String?
  cityId       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignedTo User?   @relation("AssignedIncidents", fields: [assignedToId], references: [id])
  trip       Trip?   @relation("TripIncidents", fields: [tripId], references: [id])
  driver     Driver? @relation("DriverIncidents", fields: [driverId], references: [id])
  user       User?   @relation("UserIncidents", fields: [userId], references: [id])
}

model CommunicationBroadcast {
  id             String   @id @default(cuid())
  title          String
  message        String
  targetAudience String // DRIVERS, RIDERS, MERCHANTS, FLEETS, ALL
  channels       String[] // PUSH, SMS, EMAIL, IN_APP
  cityId         String?
  sentById       String
  createdAt      DateTime @default(now())

  sentBy User @relation("BroadcastsSent", fields: [sentById], references: [id])
}

model OperationsAlert {
  id         String        @id @default(cuid())
  title      String
  message    String
  severity   AlertSeverity
  type       String // SYSTEM, FLEET, DRIVER, DEMAND, SURGE
  isResolved Boolean       @default(false)
  cityId     String?
  createdAt  DateTime      @default(now())
}

model OperationsAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminOperationsAuditLogs", fields: [adminId], references: [id])
}

// ==========================================
// CORPORATE & BUSINESS TRAVEL
// ==========================================

enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
}

model Organization {
  id              String             @id @default(cuid())
  companyName     String
  legalName       String?
  industry        String?
  companySize     String?
  taxNumber       String?
  businessLicense String?
  email           String             @unique
  phone           String?
  address         String?
  city            String?
  country         String?
  logo            String?
  status          OrganizationStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  branches    OrganizationBranch[]
  departments Department[]
  employees   Employee[]
  policies    CorporatePolicy[]
  budgets     Budget[]
  costCenters CostCenter[]
  invoices    Invoice[]
  wallet      CorporateWallet?
  contracts   Contract[]
  discounts   CorporateDiscount[]
  auditLogs   CorporateAuditLog[]
}

model OrganizationBranch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  city           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]
}

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]
  budgets      Budget[]
}

enum CorporateRoleType {
  OWNER
  ADMIN
  FINANCE_MANAGER
  TRAVEL_MANAGER
  DEPARTMENT_MANAGER
  EMPLOYEE
}

model Employee {
  id             String            @id @default(cuid())
  organizationId String
  userId         String?           @unique
  branchId       String?
  departmentId   String?
  employeeId     String?
  name           String
  email          String            @unique
  phone          String?
  jobTitle       String?
  role           CorporateRoleType @default(EMPLOYEE)
  status         EmployeeStatus    @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User?               @relation("UserEmployee", fields: [userId], references: [id])
  branch           OrganizationBranch? @relation(fields: [branchId], references: [id])
  department       Department?         @relation(fields: [departmentId], references: [id])
  approvals        TravelApproval[]    @relation("EmployeeApprovals")
  managerApprovals TravelApproval[]    @relation("ManagerApprovals")
}

model CorporatePolicy {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  rules          Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TravelApproval {
  id         String         @id @default(cuid())
  employeeId String
  managerId  String?
  tripId     String?
  status     ApprovalStatus @default(PENDING)
  reason     String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  employee Employee  @relation("EmployeeApprovals", fields: [employeeId], references: [id])
  manager  Employee? @relation("ManagerApprovals", fields: [managerId], references: [id])
  trip     Trip?     @relation("TripTravelApproval", fields: [tripId], references: [id])
}

model Budget {
  id             String   @id @default(cuid())
  organizationId String
  departmentId   String?
  amount         Decimal  @db.Decimal(12, 2)
  spent          Decimal  @default(0) @db.Decimal(12, 2)
  period         String // DAILY, WEEKLY, MONTHLY, YEARLY
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id])
}

model CostCenter {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  invoiceNumber  String        @unique
  periodStart    DateTime
  periodEnd      DateTime
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  taxes          Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        InvoiceLine[]
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  tripId      String?
  description String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CorporateWallet {
  id             String   @id @default(cuid())
  organizationId String   @unique
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  creditLimit    Decimal  @default(0) @db.Decimal(12, 2)
  currency       String   @default("AFN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Contract {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  startDate      DateTime
  endDate        DateTime
  documentUrl    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CorporateDiscount {
  id             String   @id @default(cuid())
  organizationId String
  type           String // FIXED, PERCENTAGE
  value          Decimal  @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CorporateAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String
  action         String
  details        Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ==========================================
// AIRPORT OPERATIONS SYSTEM
// ==========================================

enum AirportStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AirportZoneType {
  PICKUP
  DROPOFF
  WAITING
  VIP
  COMMERCIAL
}

enum QueueStatus {
  WAITING
  ASSIGNED
  LEFT
  SUSPENDED
}

enum FlightStatus {
  SCHEDULED
  ON_TIME
  DELAYED
  LANDED
  CANCELLED
}

model Airport {
  id          String        @id @default(cuid())
  name        String
  city        String
  country     String
  iataCode    String        @unique
  icaoCode    String        @unique
  locationLat Float?
  locationLng Float?
  terminals   String[]
  status      AirportStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  zones     AirportZone[]
  flights   Flight[]
  bookings  AirportBooking[]
  auditLogs AirportAuditLog[]
}

model AirportZone {
  id          String          @id @default(cuid())
  airportId   String
  name        String
  type        AirportZoneType
  coordinates Json? // Geo-fence polygon
  maxCapacity Int             @default(100)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  airport Airport        @relation(fields: [airportId], references: [id], onDelete: Cascade)
  queues  AirportQueue[]
}

model AirportQueue {
  id            String      @id @default(cuid())
  airportZoneId String
  driverId      String
  vehicleId     String?
  vehicleType   VehicleType @default(CAR)
  queuePosition Int         @default(0)
  entryTime     DateTime    @default(now())
  status        QueueStatus @default(WAITING)

  zone    AirportZone @relation(fields: [airportZoneId], references: [id], onDelete: Cascade)
  driver  Driver      @relation("DriverAirportQueues", fields: [driverId], references: [id], onDelete: Cascade)
  vehicle Vehicle?    @relation(fields: [vehicleId], references: [id])
}

model Flight {
  id                      String       @id @default(cuid())
  airportId               String
  flightNumber            String
  airline                 String
  arrivalTime             DateTime
  departureTime           DateTime?
  status                  FlightStatus @default(SCHEDULED)
  estimatedPassengerCount Int?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)
}

model AirportBooking {
  id           String   @id @default(cuid())
  airportId    String
  tripId       String?  @unique
  flightNumber String?
  userId       String
  driverId     String?
  type         String // PICKUP, DROPOFF
  isVIP        Boolean  @default(false)
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  airport Airport @relation(fields: [airportId], references: [id])
  trip    Trip?   @relation("TripAirportBooking", fields: [tripId], references: [id])
  user    User    @relation("UserAirportBookings", fields: [userId], references: [id])
  driver  Driver? @relation("DriverAirportBookings", fields: [driverId], references: [id])
}

model AirportAuditLog {
  id        String   @id @default(cuid())
  airportId String
  adminId   String
  action    String
  details   Json?
  createdAt DateTime @default(now())

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)
  admin   User    @relation("AdminAirportAuditLogs", fields: [adminId], references: [id])
}
