*

!.gcloudignore
!backend/
!backend/**
!gcp/
!gcp/**
!web/
!web/**

# Keep service-local build and install artifacts out of the uploaded tarball.
backend/node_modules/
backend/dist/
backend/coverage/
backend/*.log
backend/.env
backend/.env.local
backend/README.md
backend/src/**/*.spec.ts
backend/test/
backend/test/**

web/node_modules/
web/.next/
web/*.log
web/.env
web/.env.local
web/tsconfig.tsbuildinfo
web/README.md
web/src/**/*.test.ts
web/src/**/*.test.tsx
web/vitest.config.ts
web/vitest.setup.ts